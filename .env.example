# MineMore Recovery CLI Configuration
#
# Copy this file to .env and fill in your values:
#   Linux / macOS:   cp .env.example .env
#   Windows CMD:     copy .env.example .env
#   Windows PS:      Copy-Item .env.example .env
#
# IMPORTANT: Never share your .env file or commit it to git.

# Your Privy wallet private key (base58 format)
# Export this from your Privy wallet settings in the MineMore app
PRIVATE_KEY=

# Solana RPC endpoint
# Uncomment one of the free public RPCs below, or use your own.
# Free RPCs have rate limits — a dedicated RPC is recommended for reliability.
#
# Free public RPCs:
#   https://api.mainnet-beta.solana.com          (Solana Foundation — strict rate limits)
#   https://solana-mainnet.g.alchemy.com/v2/demo (Alchemy demo — moderate limits)
#   https://mainnet.helius-rpc.com/?api-key=     (Helius — requires free API key from helius.dev)
#
# If no RPC_URL is set, the tool will automatically cycle between free RPCs.
#
RPC_URL=https://api.mainnet-beta.solana.com
